PORT=3000
NODE_ENV=development

# Firebase Admin SDK
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxx@your-project.iam.gserviceaccount.com

# JWT
JWT_SECRET=your-super-secret-jwt-key-min-32-chars

# NPCI UPI Sandbox
NPCI_SANDBOX_URL=https://sandbox.npci.org.in/upi/v1
NPCI_API_KEY=your-npci-sandbox-api-key

# PostgreSQL
DATABASE_URL=postgresql://user:password@localhost:5432/paykaro

# Redis
REDIS_URL=redis://localhost:6379

# CORS
ALLOWED_ORIGINS=http://localhost:3000,https://paykaro.app
